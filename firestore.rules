rules_version = '2';

// Todo el acceso a Firestore pasa por el backend (api/index.js) usando
// Firebase Admin SDK, que ignora estas reglas. Por eso se bloquea
// cualquier acceso directo desde el navegador.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
